# URL of the Archypix backend to request a federation token from
BASE_URL=http://localhost:3000

# This test server's global (WebFinger) domain — used as requester_instance in the auth request
# and served at /.well-known/webfinger so the backend can resolve our backend URL.
GLOBAL_DOMAIN=fed-test.local

# URL the backend will call when resolving our WebFinger. Defaults to http://{GLOBAL_DOMAIN}.
# Override if the backend reaches us on a different URL than the public domain implies.
# BACKEND_URL=http://fed-test.local

# A local username to include in the auth request (used by the backend for WebFinger resolution).
# USERNAME=testuser
