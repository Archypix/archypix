# ─────────────────────────────────────────────────────────────────────────────
# MANDATORY
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ───────────────────────────────────────────────────────────────────
# Base URL of the Archypix backend this worker serves.
BACK_URL=http://backend:8000

# The backend's public domain (must match BACK_DOMAIN in the backend's .env).
# Used as the JWT audience.
BACK_DOMAIN=backend1.archypix.com

# Shared identity domain (must match GLOBAL_DOMAIN in the backend's .env).
# Used as the JWT issuer field.
GLOBAL_DOMAIN=archypix.com

# Shared JWT secret — must be identical to WORKER_JWT_SECRET in the backend's .env.
WORKER_JWT_SECRET=change-me-in-production

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL  (shown with their default values)
# ─────────────────────────────────────────────────────────────────────────────

# ── Worker identity ───────────────────────────────────────────────────────────
# Unique name for this worker instance. Shown in job logs and the claimed_by field.
# Defaults to a random suffix if not set.
WORKER_ID=worker-1

# ── Job processing ────────────────────────────────────────────────────────────
# How often (milliseconds) to poll the backend for new jobs when idle.
POLL_INTERVAL_MS=1000

# Maximum number of jobs processed concurrently by this instance.
MAX_CONCURRENT_JOBS=2

# Comma-separated list of job types this worker handles.
# When empty, the worker accepts all job types.
JOB_TYPES=gen_thumbnail,edit_picture

# ── HTTP server (health check) ────────────────────────────────────────────────
LISTEN_ADDR=0.0.0.0:80

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info,archypix_worker=debug
