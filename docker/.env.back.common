# Common environment variables shared between all backend containers in the dev compose.
# Per-backend settings (domain, DB, Redis, JWT secrets, S3 buckets) must be set per-service.

# Logging
RUST_LOG=info,archypix_back=trace

# CORS — allow any origin in dev
CORS_ORIGINS=*

# Use HTTP for both public URLs and federation in dev
BACK_USE_HTTPS=false
WEBFINGER_USE_HTTPS=false

WORKER_JWT_SECRET=test

# S3 — internal address used by the backend for uploads/downloads,
# public address used in presigned URLs returned to browsers.
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=archypix
S3_SECRET_KEY=archypix
