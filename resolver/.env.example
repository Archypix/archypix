# Database connection
DATABASE_URL=postgres://archypix:archypix@localhost/archypix_resolver

# Domain in user account (@user:domain) managed by this resolver
MANAGED_DOMAIN=archypix.com

# JWT secret for resolver update API (change in production!)
RESOLVER_ADMIN_SECRET=change-me-in-production

# Server configuration
LISTEN_ADDR=0.0.0.0:8080

# Cache configuration
CACHE_TTL_SECS=3600
CACHE_MAX_CAPACITY=100000

# Frontend origin for CORS. Use * to allow any origin (dev only).
FRONT_URL=https://archypix.com

# Logging
RUST_LOG=info,archypix_resolver=debug
