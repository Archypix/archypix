# ─────────────────────────────────────────────────────────────────────────────
# MANDATORY
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────
DB_HOST=postgres-host
DB_USER=archypix
DB_PASSWORD=change-me-in-production
DB_NAME=archypix_resolver

# ── Identity ──────────────────────────────────
# The global identity domain managed by this resolver: the part after ':' in
# user handles (@user:global_domain). Must match the GLOBAL_DOMAIN set on all
# backends that register with this resolver.
GLOBAL_DOMAIN=archypix.com

# Shared JWT secret used to authenticate backends communicating with this
# resolver. Both the resolver and every registered backend must use the same
# value (set RESOLVER_JWT_SECRET to the same value on each backend).
RESOLVER_JWT_SECRET=change-me-in-production

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed browser origins for the API.
# Use a single '*' to allow any origin (development only — never in production).
CORS_ORIGINS=https://archypix.com


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL  (shown with their default values)
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────
LISTEN_ADDR=0.0.0.0:80

# ── Database ──────────────────────────────────
DB_PORT=5432

# ── Cache ─────────────────────────────────────
# How long (seconds) a username→backend mapping is kept in the in-process cache
# before being re-read from the database.
CACHE_TTL_SECS=3600

# Maximum number of entries in the in-process cache.
CACHE_MAX_CAPACITY=100000
