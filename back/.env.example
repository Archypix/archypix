# ─────────────────────────────────────────────────────────────────────────────
# MANDATORY
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────
DB_HOST=postgres-host
DB_USER=archypix
DB_PASSWORD=change-me-in-production
DB_NAME=archypix_back

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis-host
REDIS_PASSWORD=change-me-in-production

# ── S3 / Object storage ───────────────────────
S3_ENDPOINT=https://s3.example.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=change-me-in-production

# ── Domain / Identity ─────────────────────────
# This backend's public domain (host:port, no scheme). Used as the JWT audience
# and to build WebFinger response hrefs.
BACK_DOMAIN=backend1.archypix.com

# Shared identity domain: the part after ':' in user handles (@user:global_domain).
# All backends sharing a user namespace must agree on this value.
# GLOBAL_DOMAIN can differ from BACK_DOMAIN regardless of USE_RESOLVER — you can
# host your backend at backend.example.com while identities are @user:example.com
# by forwarding /.well-known/webfinger on example.com to this backend via a
# reverse proxy (the same delegation pattern used by Matrix/Element).
GLOBAL_DOMAIN=archypix.com

# Whether this backend is fronted by TLS (HTTPS). Affects public URL construction
# and the scheme used in WebFinger responses.
BACK_USE_HTTPS=true

# ── Auth ──────────────────────────────────────
# Whether multiple backends share the same GLOBAL_DOMAIN via a resolver.
# false → standalone instance; this backend serves its own WebFinger endpoint
#         directly (or via a reverse-proxy delegate).
# true  → a resolver owns the WebFinger for GLOBAL_DOMAIN and routes both
#         lookups and new user registrations across the pool of backends.
USE_RESOLVER=true

# Master secret for signing user access tokens, refresh tokens, and federation
# tokens. Must be a long random string. Never reuse across instances.
JWT_SECRET=change-me-in-production

# ── Resolver (required when USE_RESOLVER=true) ──
# Shared JWT secret between this backend and the resolver. Both sides must use
# the same value so each can verify tokens issued by the other.
RESOLVER_JWT_SECRET=change-me-in-production

# ── Workers ───────────────────────────────────
# Shared JWT secret between this backend and all worker instances. Both sides
# must use the same value so the backend can verify worker tokens.
WORKER_JWT_SECRET=change-me-in-production

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed browser origins for the API.
# Use a single '*' to allow any origin (development only — never in production).
CORS_ORIGINS=https://archypix.com


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL  (shown with their default values)
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────
LISTEN_ADDR=0.0.0.0:80

# ── Database ──────────────────────────────────
DB_PORT=5432

# ── Redis ─────────────────────────────────────
REDIS_PORT=6379
# Default Redis username (leave unset if your Redis has no ACL user configured).
REDIS_USER=default
# Database index (0–15). Separate backends sharing a Redis instance should use
# different indices so their keys are isolated.
REDIS_DB=0

# ── Resolver ──────────────────────────────────
# Internal URL of the resolver, reachable from this backend. May differ from
# the public resolver URL when resolver and backend share a private network
# (Docker, VPC). Defaults to {BACK_USE_HTTPS scheme}://{GLOBAL_DOMAIN}.
RESOLVER_INTERNAL_URL=https://archypix.com

# Internal URL that the resolver uses to reach THIS backend for API calls
# (e.g. user creation). Defaults to the public base URL derived from BACK_DOMAIN.
# Override when on a shared private network so the resolver uses the container
# hostname instead of the public domain.
BACK_INTERNAL_URL=https://backend1.archypix.com

# ── Federation ────────────────────────────────
# Whether to use HTTPS when resolving remote backends via WebFinger
# (.well-known/webfinger calls). All subsequent API calls to resolved
# backends use the scheme embedded in the backend_url the resolver returns,
# so this only affects the initial WebFinger query.
# Set to false in local/Docker environments where inter-service traffic is HTTP.
WEBFINGER_USE_HTTPS=true

# ── Auth / Token TTLs ─────────────────────────
# How long a user access token is valid (seconds). Short TTL limits exposure if
# a token leaks; the client refreshes it transparently using the refresh token.
ACCESS_TOKEN_TTL_SECS=900

# How long a refresh token is valid (seconds). Controls the "stay logged in"
# window — users must log in again once this expires.
REFRESH_TOKEN_TTL_SECS=15552000

# ── Federation ────────────────────────────────
# How long a federation token (instance-to-instance auth) is valid (seconds).
# Tokens are cached per remote instance and reused, so a long TTL greatly
# reduces handshake overhead.
FEDERATION_JWT_TTL_SECS=86400

# How long (seconds) a resolved backend domain is cached in Redis to avoid
# repeated WebFinger lookups for the same remote instance.
FEDERATION_BACKEND_CACHE_TTL_SECS=3600

# Maximum time (ms) to wait for a federation request to a remote backend.
# Keep this low so a slow/unreachable remote does not stall list endpoints.
FEDERATION_REQUEST_TIMEOUT_MS=1000

# ── Workers ───────────────────────────────────────────────────────────────────
# Maximum number of in-process background tasks running concurrently
# (tag-rename, etc.). Does not affect external workers.
TASK_QUEUE_CONCURRENCY=4

# How often (seconds) the tagging pipeline loop runs a recovery sweep,
# catching pictures missed due to restarts. Event-driven wakes happen immediately.
PIPELINE_POLL_INTERVAL_SECS=3600

# Milliseconds to sleep between picture batches in the pipeline.
# Increase under heavy load to prevent the pipeline from overloading the database and the backend.
PIPELINE_BATCH_SLEEP_MS=0

# Maximum number of users whose tagging pipeline runs concurrently. Runs are
# serialized per user and parallel across users.
PIPELINE_CONCURRENCY=4

# Backoff (seconds) before a share whose announce/unannounce delivery failed
# (status 'errored' or 'pending_first_announcement') is retried by the pipeline.
PIPELINE_RETRY_BACKOFF_SECS=60

# How long (seconds) a job may remain in `processing` state before the watchdog
# considers the worker dead and resets it to `pending` (or `failed` if retries
# are exhausted). Should be longer than the longest expected job runtime.
JOB_PROCESSING_TIMEOUT_SECS=600

# How often (seconds) the watchdog scans for stuck jobs.
JOB_WATCHDOG_INTERVAL_SECS=60

# ── S3 / Object storage ───────────────────────
# S3 region (informational for most S3-compatible stores, required for AWS S3).
S3_REGION=us-east-1

# Public-facing S3 endpoint embedded in presigned URLs returned to browsers.
# Defaults to S3_ENDPOINT. Override when the internal and external addresses
# differ — e.g. backend reaches MinIO at http://minio:9000 (Docker network)
# but browsers must use http://localhost:9000 (host-exposed port).
S3_PUBLIC_ENDPOINT=http://localhost:9000

# S3 endpoint embedded in presigned URLs handed to worker processes.
# Defaults to S3_ENDPOINT. Override when workers reach MinIO via a different
# address than browsers — e.g. workers on the same Docker network use
# http://minio:9000 directly instead of going through the public endpoint.
S3_WORKERS_ENDPOINT=http://minio:9000

# How long (seconds) a presigned GET/PUT URL is valid.
S3_PRESIGN_TTL_SECS=3600

# How many seconds before expiry a presigned URL is considered stale and
# regenerated to avoid serving near-expired URLs to clients.
S3_PRESIGN_CACHE_MARGIN_SECS=600

# Bucket names. All buckets except staging can share the same bucket (data is
# namespaced by object key). S3_BUCKET_STAGING MUST be a dedicated bucket
# because an automatic 1-day expiration rule is applied to it at startup.
S3_BUCKET_STAGING=archypix-staging     # Temporary uploads, auto-expires in 1 day
S3_BUCKET_PICTURES=archypix-pictures   # Original picture files (immutable after upload)
S3_BUCKET_VERSIONS=archypix-versions   # Processed / edited variants
S3_BUCKET_SMALL=archypix-small         # Thumbnail — small
S3_BUCKET_MEDIUM=archypix-medium       # Thumbnail — medium
S3_BUCKET_LARGE=archypix-large         # Thumbnail — large
