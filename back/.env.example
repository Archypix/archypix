# Database connection
DATABASE_URL=postgres://archypix:archypix@localhost/archypix_back

# Server configuration
LISTEN_ADDR=0.0.0.0:8000

# Logging
RUST_LOG=info,archypix_back=debug

# Frontend url for CORS policy
FRONT_URL=https://archypix.com

# Using a resolver allows multiple backends to share the same domain with the federation protocol.
# The webfinger protocol will be used to detect which instance is responsible for a user.
USE_RESOLVER=true
# This backend’s host, used to register to the resolver if using one.
HOST=b1.archypix.com
# Public base URL for callbacks
PUBLIC_BASE_URL=https://b1.archypix.com
# The domain that appears after the ':' in usernames (@user:domain.com).
# Its path /.well-known/webfinger should provide the backend url.
# You can connect /.well-known/webfinger to RESOLVER_URL with a reverse proxy.
# If not using a resolver, WEBFINGER_HOST should be equals to HOST
WEBFINGER_HOST=archypix.com
# The url of the resolver for webfinger and update requests. Can be an internal address. Can be equals to http://WEBFINGER_HOST.
# Optional if not using any resolver
RESOLVER_URL=http://archypix_resolver
# Optional if not using any resolver
# JWT secret allowing this backend to update the resolver.
RESOLVER_ADMIN_SECRET=change-me-in-production

# JWT secret for user/admin/federation tokens
JWT_SECRET=change-me-in-production
# Access/refresh token TTLs
ACCESS_TOKEN_TTL_SECS=900
REFRESH_TOKEN_TTL_SECS=2592000
# Federation JWT TTL (seconds)
FEDERATION_JWT_TTL_SECS=900
# Federation backend mapping cache TTL (seconds)
FEDERATION_BACKEND_CACHE_TTL_SECS=3600
# Federation request timeout (ms)
FEDERATION_REQUEST_TIMEOUT_MS=5000
# Federation scheme for remote backend URLs
FEDERATION_SCHEME=https

# Redis
REDIS_URL=redis://redis:archypix@localhost:6379

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=archypix
S3_SECRET_KEY=archypix
S3_REGION=us-east-1
S3_PRESIGN_TTL_SECS=3600
S3_PRESIGN_CACHE_MARGIN_SECS=600
# S3 bucket names. It is possible to use the same bucket multiple times to store everything in
# the same bucket. But S3_BUCKET_STAGING should be a dedicated bucket because it has specific
# expiration rules configured
S3_BUCKET_STAGING=archypix-staging
S3_BUCKET_PICTURES=archypix-pictures
S3_BUCKET_VERSIONS=archypix-versions
S3_BUCKET_SMALL=archypix-small
S3_BUCKET_MEDIUM=archypix-medium
S3_BUCKET_LARGE=archypix-large
