{
  "db_name": "PostgreSQL",
  "query": "SELECT p.id, p.captured_at, p.gps_lat, p.gps_lng, p.filename\n               FROM pictures p\n               WHERE p.local_user_id = $1\n                 AND (\n                   (p.last_pipeline_run_at IS NULL)\n                   OR\n                   EXISTS (\n                     SELECT 1 FROM tagging_services ts\n                     WHERE ts.owner_id = $1\n                       AND ts.enabled = true\n                       AND p.last_pipeline_run_at < ts.last_invalidated_at\n                   )\n                 )",
