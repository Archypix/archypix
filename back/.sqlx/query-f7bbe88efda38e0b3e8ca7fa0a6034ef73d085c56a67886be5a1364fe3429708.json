  "query": "\n            SELECT id, user_id, token_hash, expires_at, revoked_at, created_at, updated_at\n            FROM refresh_tokens\n            WHERE token_hash = $1\n              AND revoked_at IS NULL\n              AND expires_at > (now() at time zone 'utc')\n            ",
