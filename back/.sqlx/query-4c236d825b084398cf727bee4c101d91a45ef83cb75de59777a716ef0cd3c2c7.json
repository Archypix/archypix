  "query": "UPDATE jobs\n               SET status     = 'processing',\n                   started_at = (now() AT TIME ZONE 'utc'),\n                   claimed_by = $2\n               WHERE id = $1\n               RETURNING\n                   id, owner_id,\n                   job_type    AS \"job_type: JobType\",\n                   status      AS \"status: JobStatus\",\n                   config      AS \"config: _\",\n                   result      AS \"result: _\",\n                   error_message,\n                   retry_count, max_retries,\n                   idempotency_key,\n                   picture_id, claimed_by,\n                   created_at, started_at, completed_at",
