  "query": "\n            INSERT INTO user_credentials (user_id, password_hash)\n            VALUES ($1, $2)\n            ON CONFLICT (user_id)\n            DO UPDATE SET password_hash = $2\n            RETURNING user_id, password_hash, created_at, updated_at\n            ",
