# Common environment variables shared between all worker containers in the dev compose.
# Per-worker settings (WORKER_ID, BACK_URL, BACK_DOMAIN, GLOBAL_DOMAIN) are set per-service.

WORKER_JWT_SECRET=test

POLL_INTERVAL_MS=1000
MAX_CONCURRENT_JOBS=2
JOB_TYPES=gen_thumbnail,edit_picture

RUST_LOG=info,archypix_worker=debug
